<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FCLiveToolApplication.VideoSharePage"
             x:Name="VideoShareContentPage"
             xmlns:vm="clr-namespace:FCLiveToolApplication.ViewModel"
             Title="VideoSharePage">

    <ContentPage.Resources>
        <DataTemplate x:Key="VideoShareListStyle">
            <ViewCell>
                <Grid Margin="20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <StackLayout Margin="0,10">
                        <StackLayout>
                            <Label Text="{Binding SourceName}" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding Tag}" FontSize="14"  LineBreakMode="TailTruncation"/>
                        </StackLayout>

                        <StackLayout Orientation="Horizontal">
                            <StackLayout BackgroundColor="Green" IsVisible="{Binding isHTTPS}" Padding="5,0">
                                <Label TextColor="White" Text="HTTPS"/>
                            </StackLayout>
                            <StackLayout BackgroundColor="Purple" Padding="5,0" Margin="5,0,0,0">
                                <Label TextColor="White" Text="{Binding URLProtocol}">
     <!--
                                                                   <Label.Style>
                                   <Style TargetType="Label">
                                       <Style.Triggers>
                                           <DataTrigger Binding="{Binding isIPV6}" Value="True">
                                               <Setter Property="Text" Value="IPV6"/>
                                           </DataTrigger>                    
                                           <DataTrigger Binding="{Binding isIPV6}" Value="False">
                                               <Setter Property="Text" Value="IPV4"/>
                                           </DataTrigger>
                                       </Style.Triggers>
                                   </Style>
                               </Label.Style>
                                    -->
                                </Label>
                            </StackLayout>
                        </StackLayout>

                        <Label Text="{Binding SourceLink}" LineBreakMode="TailTruncation"/>
                        <StackLayout Orientation="{OnPlatform Horizontal,Android=Vertical}" Margin="0,10,0,0">
                            <HorizontalStackLayout>
                                <Label Text="分享时间："/>
                                <Label Text="{Binding UploadTime}" FontSize="14"  LineBreakMode="TailTruncation"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout>
                                <Label Text="最后检测有效时间：" Margin="{ OnPlatform '10,0,0,0', Android=0}"/>
                                <Label Text="{Binding LastCheckTime}" FontSize="14"  LineBreakMode="TailTruncation"/>
                            </HorizontalStackLayout>
                        </StackLayout>
                    </StackLayout>

                    <StackLayout Grid.Column="1" Margin="20,0,0,0">
                        <Button Command="{Binding Source={x:Reference VideoShareContentPage}, Path=BindingContext.M3UUpdateCommand}" CommandParameter="{Binding SourceLink}" Text="{OnPlatform '重新检测',Android=''}"  IsEnabled="{Binding Source={x:Reference VideoSharePage}, Path=BindingContext.M3UUpdateEnabled}" WidthRequest="{OnPlatform Android=50}" HorizontalOptions="{OnPlatform Android=End}" Background="{OnPlatform Transparent,Android=LightPink}">
                            <Button.ImageSource>
                                <FontImageSource Glyph="&#xE72C;" Size="Micro" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                            </Button.ImageSource>
                        </Button>
                        <Button Command="{Binding Source={x:Reference VideoShareContentPage}, Path=BindingContext.M3UPlayCommand}" CommandParameter="{Binding SourceLink}"  Text="{OnPlatform '点击试看',Android=''}" IsEnabled="{Binding Source={x:Reference VideoSharePage}, Path=BindingContext.M3UPlayEnabled}" WidthRequest="{OnPlatform Android=50}" HorizontalOptions="{OnPlatform Android=End}" Background="{OnPlatform Transparent,Android=LightPink}" Margin="0,5,0,0">
                            <Button.ImageSource>
                                <FontImageSource Glyph="&#xEDB5;" Size="Micro" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                            </Button.ImageSource>
                        </Button>
                        <Button Command="{Binding Source={x:Reference VideoShareContentPage}, Path=BindingContext.M3UDownloadCommand}" CommandParameter="{Binding SourceLink}" Text="{OnPlatform '点击下载',Android=''}" IsEnabled="{Binding Source={x:Reference VideoSharePage}, Path=BindingContext.M3UDownloadEnabled}" WidthRequest="{OnPlatform Android=50}" HorizontalOptions="{OnPlatform Android=End}" Background="{OnPlatform Transparent,Android=LightPink}" Margin="0,5,0,0">
                            <Button.ImageSource>
                                <FontImageSource Glyph="&#xE896;" Size="Small" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                            </Button.ImageSource>
                        </Button>
                    </StackLayout>
                </Grid>
            </ViewCell>
        </DataTemplate>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:VideoSharePageViewModel/>
    </ContentPage.BindingContext>
    
    
    <Shell.TitleView>
        <HorizontalStackLayout>
            <Label Text="直播源共享" TextColor="#A0F0FFFF" FontSize="Large" VerticalTextAlignment="Center"/>
        </HorizontalStackLayout>
    </Shell.TitleView>


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            
            <StackLayout Grid.ColumnSpan="2">
                <Label Text="在此页面，你可以看到所有人分享的直播源，你可以直接下载，也可以分享自己的直播源。" LineBreakMode="WordWrap"/>
                <Label Text="若要检测直播源，请在下方输入直播源地址，然后点击检测，如果直播源检测结果为有效，会自动分享至数据库。分享的直播源链接格式暂时只支持HTTP协议。" LineBreakMode="WordWrap"/>
            </StackLayout>

            <StackLayout Margin="{ OnPlatform Android='0,10,0,0'}" Grid.Row="1">
                <Entry  Text="{Binding M3USourceURL}" HeightRequest="{ OnPlatform 30,Android=40}" ClearButtonVisibility="WhileEditing"/>
            </StackLayout>
            <Grid Margin="{ OnPlatform '10,0,0,0' ,Android='10,10,0,0'}" Grid.Row="1" Grid.Column="1">
                <Button Text="检测并分享" Background="LightPink" IsEnabled="{Binding M3UAnalysisBtnEnable}" VerticalOptions="Start" Command="{Binding M3UAnalysisBtnCommand}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xEDE4;" Size="Small" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                    </Button.ImageSource>
                </Button>
            </Grid>
            
            <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="10,0,0,0">
                <StackLayout Orientation="Horizontal">
                    <Button  Text="刷新列表" IsEnabled="{Binding M3URefreshBtnEnable}" Background="LightBlue" Command="{Binding M3URefreshBtnCommand}">
                        <Button.ImageSource>
                            <FontImageSource Glyph="&#xEDE4;" Size="Small" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                        </Button.ImageSource>
                    </Button>
                </StackLayout>

            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <ListView ItemTemplate="{StaticResource VideoShareListStyle}" ItemsSource="{Binding SharedVideos}" RowHeight="{ OnPlatform Android= 150}" IsPullToRefreshEnabled="True" HorizontalScrollBarVisibility="Never"  IsRefreshing="False" RefreshCommand="{Binding RefreshCommand}"/>
            <ActivityIndicator IsRunning="{Binding VideoShareListRingRunning}" HorizontalOptions="Center" VerticalOptions="{ OnPlatform Center, Android= Start}" Margin="{ OnPlatform Android= '0,50,0,0'}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <StackLayout Orientation="Horizontal"  HorizontalOptions="Center" VerticalOptions="Start" IsVisible="{Binding VSLPagePanelVisible}">
                <Button Background="LightPink" ContentLayout="0" HorizontalOptions="Start" Command="{Binding VSLBackBtnCommand}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xE0E2;" Size="Small" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                    </Button.ImageSource>
                </Button>
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Margin="40,0,0,0">
                    <Label Text="{Binding VSLCurrentPageIndex}" FontSize="24" HorizontalOptions="Center"/>
                    <Entry Text='{Binding VSLPageTb}' MaxLength="3" Placeholder="输入页码" Keyboard="Numeric" Margin="10,0,0,0"/>
                    <Button Background="LightBlue" HeightRequest="35" Text="跳转" Margin="{ OnPlatform '10,0,0,0', Android=0}" Command="{Binding VSLJumpBtnCommand}"/>
                </StackLayout>
                <Button Background="LightPink" ContentLayout="0" HorizontalOptions="End" Margin="40,0,0,0" Command="{Binding VSLNextBtnCommand}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xE0E3;" Size="Small" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                    </Button.ImageSource>
                </Button>
            </StackLayout>
            
            
        </Grid>


    </Grid>
    
</ContentPage>