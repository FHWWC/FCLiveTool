<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FCLiveToolApplication.AppSettingPage"
             xmlns:vm="clr-namespace:FCLiveToolApplication.ViewModel"
             Title="AppSettingPage">

    <Shell.TitleView>
        <HorizontalStackLayout>
            <Label Text="设置" TextColor="#A0F0FFFF" FontSize="Large" VerticalTextAlignment="Center"/>
        </HorizontalStackLayout>
    </Shell.TitleView>
    
    <ContentPage.BindingContext>
        <vm:AppSettingPageViewModel/>
    </ContentPage.BindingContext>
    
    <StackLayout Margin="20">
        <Label Text="播放设置：" FontSize="Medium"/>
        <StackLayout Margin="0,10,0,0">
            <HorizontalStackLayout>
                <Label Text="打开APP默认播放的直播源" Margin="0,5,0,0"/>
                <Button x:Name="ShowDPInput" Background="Transparent" WidthRequest="50" Command="{Binding ShowDPInputCommand}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xE70F;" Size="Micro" Color="Black" FontFamily="Segoe MDL2 Assets"/>
                    </Button.ImageSource>
                </Button>
            </HorizontalStackLayout>
            <Label Text="{Binding DefaultPlayM3U8Name}" FontAttributes="Bold"/>
            <Label Text="{Binding DefaultPlayM3U8URL}" HorizontalOptions="Start" MaximumWidthRequest="400" TextDecorations="Underline"/>

            <StackLayout Margin="0,5,0,0">
                <Label Text="打开APP自动播放直播源"/>
                <Switch x:Name="StartAutoPlayToogleBtn" IsToggled="{Binding StartAutoPlayToogle}" HorizontalOptions="Start"/>
            </StackLayout>
        </StackLayout>
        
        <Label Text="界面设置：" FontSize="Medium" Margin="0,15,0,0"/>
        <StackLayout Margin="0,10,0,0">
            <StackLayout>
                <Label Text="主题模式"/>
                <Picker SelectedIndex="{Binding ThemeType}" HorizontalOptions="Start">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>跟随系统</x:String>
                            <x:String>浅色</x:String>
                            <x:String>深色</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
<!--
                                <Switch x:Name="DarkModeToogleBtn" IsToggled="{Binding DarkModeToogle}" HorizontalOptions="Start" Toggled="DarkModeToogleBtn_Toggled"/>
                -->
            </StackLayout>
            
            <!--
                        <Label Text="旋转模式"/>
            -->
        </StackLayout>
    </StackLayout>
    
</ContentPage>